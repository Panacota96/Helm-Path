FROM kalilinux/kali-rolling

# Avoid interactive prompts during build
ENV DEBIAN_FRONTEND=noninteractive

# Update and install ONLY essential tools
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    git \
    vim \
    zsh \
    sudo \
    net-tools \
    iputils-ping \
    bsdutils \
    nmap \
    netcat-traditional \
    python3 \
    && rm -rf /var/lib/apt/lists/*

# Install Ollama
RUN curl -fsSL https://ollama.com/install.sh | sh

# Create a non-root user 'durk'
RUN useradd -m -s /usr/bin/zsh durk && \
    echo "durk ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/durk && \
    chmod 0440 /etc/sudoers.d/durk

# Switch to the new user
USER durk
WORKDIR /home/durk

# Install Oh-My-Zsh for the Chronicler's interface (User Level)
RUN sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended

# Install Zsh Plugins (Autosuggestions & Syntax Highlighting)
RUN git clone https://github.com/zsh-users/zsh-autosuggestions ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-autosuggestions && \
    git clone https://github.com/zsh-users/zsh-syntax-highlighting.git ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting

# Enable Plugins in .zshrc
RUN sed -i 's/plugins=(git)/plugins=(git zsh-autosuggestions zsh-syntax-highlighting)/' ~/.zshrc

# Configure the Watcher's Path (Logging)
# Ensure the helm-path directory is writable by the user
USER root
RUN mkdir -p /helm-path && chown durk:durk /helm-path
USER durk

# Add logging script to user's .zshrc
RUN echo 'if [ -z "$SCRIPT_LOGGED" ]; then export SCRIPT_LOGGED=1; script -f -q /helm-path/${LOG_FILE:-session.log}; exit; fi' >> /home/durk/.zshrc

# Welcome Message
RUN echo 'echo -e "\n\033[1;33m🛡️  The Watcher (Lite) is ready. You are guarding as: Durk\033[0m\n"' >> /home/durk/.zshrc

CMD ["/usr/bin/zsh"]
